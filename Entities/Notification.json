{
  "name": "Notification",
  "type": "object",
  "properties": {
    "channel": {
      "type": "string",
      "enum": [
        "in_app",
        "email",
        "whatsapp"
      ],
      "default": "in_app"
    },
    "recipient_user_id": {
      "type": "string"
    },
    "recipient_email": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "related_entity_type": {
      "type": "string"
    },
    "related_entity_id": {
      "type": "string"
    },
    "related_url": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Sent",
        "Failed",
        "Read"
      ],
      "default": "Pending"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "read_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_message": {
      "type": "string"
    },
    "location_id": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "message"
  ]
}