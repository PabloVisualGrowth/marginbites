{
  "name": "PurchaseOrder",
  "type": "object",
  "properties": {
    "po_number": {
      "type": "string",
      "description": "N\u00famero de pedido (PO-YYYY-####)"
    },
    "location_id": {
      "type": "string"
    },
    "location_name": {
      "type": "string"
    },
    "supplier_id": {
      "type": "string"
    },
    "supplier_name": {
      "type": "string"
    },
    "order_date": {
      "type": "string",
      "format": "date"
    },
    "requested_delivery_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Suggested",
        "Sent",
        "Partially_Received",
        "Received",
        "Cancelled"
      ],
      "default": "Draft"
    },
    "source": {
      "type": "string",
      "enum": [
        "manual",
        "auto_suggestion"
      ],
      "default": "manual"
    },
    "notes": {
      "type": "string"
    },
    "sent_via": {
      "type": "string",
      "enum": [
        "email",
        "whatsapp",
        "none"
      ],
      "default": "none"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_estimated_amount": {
      "type": "number",
      "default": 0
    },
    "lines_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "location_id",
    "supplier_id"
  ]
}